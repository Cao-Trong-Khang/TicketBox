NODE_ENV=production
PORT=3000
FRONTEND_ORIGIN=https://your-frontend.example.com
PUBLIC_API_ORIGIN=https://your-backend.example.com

DATABASE_URL=postgresql://user:password@host:5432/ticketbox?schema=public

JWT_ACCESS_SECRET=replace-with-a-long-random-production-secret
JWT_ACCESS_TOKEN_TTL=1h

CHECK_IN_QR_HMAC_SECRET=replace-with-at-least-32-random-characters
CHECK_IN_QR_ISSUER=ticketbox
CHECK_IN_QR_EXPIRATION_GRACE_SECONDS=604800
CHECK_IN_QR_TOKEN_TTL_SECONDS=2592000
CHECK_IN_MAX_CLOCK_SKEW_SECONDS=300
CHECK_IN_OFFLINE_GRACE_SECONDS=86400

REDIS_URL=redis://user:password@host:6379
REDIS_HOST=host
REDIS_PORT=6379

KAFKA_BROKERS=host:9092

MINIO_ENDPOINT=host
MINIO_PORT=9000
MINIO_USE_SSL=true
MINIO_ACCESS_KEY=replace-with-access-key
MINIO_SECRET_KEY=replace-with-secret-key
MINIO_BUCKET=artist-documents
MINIO_TIMEOUT_MS=10000
BANNERS_BUCKET=concert-banners
BANNERS_MAX_FILE_SIZE=5242880
BANNERS_CACHE_MAX_AGE=86400

AI_PROVIDER=mock
AI_MODEL=mock-biography-v1
AI_BIO_PROCESSING_MODE=worker
AI_API_KEY=
GEMINI_API_KEY=
AI_BASE_URL=
AI_TIMEOUT_MS=30000
AI_RATE_LIMIT_RETRY_MS=60000
AI_TEXT_MAX_CHARS=4000
PDF_MIN_TEXT_CHARS=50

VIP_CSV_SOURCE_DIR=./prisma/demo-sponsor-csv
VIP_CSV_DEFAULT_SOURCE_NAME=SPONSOR_CSV
VIP_IMPORT_MAX_FILE_SIZE_BYTES=10485760
VIP_IMPORT_MAX_ROWS=10000
VIP_IMPORT_BATCH_SIZE=100
VIP_IMPORT_WORKER_BATCH_LIMIT=10
VIP_IMPORT_SCAN_INTERVAL_MS=60000
VIP_IMPORT_WORKER_POLL_INTERVAL_MS=10000
VIP_IMPORT_QUEUE_FAIL=0

VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_IPN_URL=https://your-backend.example.com/payments/webhooks/vnpay
VNPAY_RETURN_URL=https://your-frontend.example.com/payments/success
VNPAY_QUERY_URL=https://sandbox.vnpayment.vn/merchant_webapi/api/transaction
VNPAY_TIMEOUT_MS=10000
VNPAY_QUERY_TIMEOUT_MS=30000

MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_IPN_URL=https://your-backend.example.com/payments/webhooks/momo
MOMO_RETURN_URL=https://your-frontend.example.com/payments/success
MOMO_QUERY_URL=https://test-payment.momo.vn/v2/gateway/api/query
MOMO_TIMEOUT_MS=10000
MOMO_QUERY_TIMEOUT_MS=30000

PAYMENT_DEMO_VNPAY_BEHAVIOR=off
PAYMENT_DEMO_MOMO_BEHAVIOR=off
PAYMENT_DEMO_DELAY_MS=0
PAYMENT_CIRCUIT_FAILURE_THRESHOLD=5
PAYMENT_CIRCUIT_OPEN_MS=60000
PAYMENT_CIRCUIT_PROBE_MS=10000
PAYMENT_RECONCILIATION_BATCH_SIZE=25
PAYMENT_RECONCILIATION_STALE_MS=60000
