NODE_ENV=development
PORT=3000
FRONTEND_ORIGIN=http://localhost:5173

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=ticketbox
POSTGRES_PASSWORD=ticketbox
POSTGRES_DB=ticketbox
DATABASE_URL=postgresql://ticketbox:ticketbox@localhost:5434/ticketbox?schema=public

JWT_ACCESS_SECRET=replace-with-local-development-secret
JWT_ACCESS_TOKEN_TTL=1h

CHECK_IN_QR_HMAC_SECRET=replace-with-local-checkin-qr-secret
CHECK_IN_QR_ISSUER=ticketbox
CHECK_IN_QR_EXPIRATION_GRACE_SECONDS=604800
CHECK_IN_QR_TOKEN_TTL_SECONDS=2592000
CHECK_IN_MAX_CLOCK_SKEW_SECONDS=300
CHECK_IN_OFFLINE_GRACE_SECONDS=86400

REDIS_HOST=localhost
REDIS_PORT=6379

KAFKA_BROKERS=localhost:9092

VIP_CSV_SOURCE_DIR=./prisma/demo-sponsor-csv
VIP_CSV_DEFAULT_SOURCE_NAME=SPONSOR_CSV
VIP_IMPORT_BATCH_SIZE=100
VIP_IMPORT_KAFKA_FAIL=0

ORGANIZER_EMAIL=org@gmail.com
ORGANIZER_PASSWORD=12345678
