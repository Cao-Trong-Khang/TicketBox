NODE_ENV=development
PORT=3000
FRONTEND_ORIGIN=http://localhost:5173

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=ticketbox
POSTGRES_PASSWORD=ticketbox
POSTGRES_DB=ticketbox
DATABASE_URL=postgresql://ticketbox:ticketbox@localhost:5434/ticketbox?schema=public

JWT_ACCESS_SECRET=replace-with-local-development-secret
JWT_ACCESS_TOKEN_TTL=1h

REDIS_HOST=localhost
REDIS_PORT=6379

KAFKA_BROKERS=localhost:9092
AI_BIO_TOPIC=ai.bio.requested
AI_BIO_GROUP_ID=ticketbox-ai-bio-worker

MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=ticketbox
MINIO_SECRET_KEY=ticketbox-minio-secret
MINIO_BUCKET=artist-documents
