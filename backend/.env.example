AI_PROVIDER=mock
AI_MODEL=mock-biography-v1
AI_API_KEY=
AI_BASE_URL=
AI_TIMEOUT_MS=30000
AI_RATE_LIMIT_RETRY_MS=60000
AI_TEXT_MAX_CHARS=4000
PDF_MIN_TEXT_CHARS=50

VIP_CSV_SOURCE_DIR=./prisma/demo-sponsor-csv
VIP_CSV_DEFAULT_SOURCE_NAME=SPONSOR_CSV
VIP_IMPORT_BATCH_SIZE=100
