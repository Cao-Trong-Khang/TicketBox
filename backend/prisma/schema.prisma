generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================
// ENUMS
// =====================

enum UserStatus {
  ACTIVE
  DISABLED

  @@map("user_status")
}

enum ConcertStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  FINISHED

  @@map("concert_status")
}

enum TicketTypeStatus {
  ACTIVE
  INACTIVE
  SOLD_OUT

  @@map("ticket_type_status")
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  EXPIRED
  CANCELLED

  @@map("order_status")
}

enum PaymentProvider {
  VNPAY
  MOMO

  @@map("payment_provider")
}

enum PaymentStatus {
  INITIATED
  PENDING
  SUCCESS
  FAILED
  TIMEOUT
  REQUIRES_REVIEW

  @@map("payment_status")
}

enum TicketStatus {
  ACTIVE
  USED
  CANCELLED

  @@map("ticket_status")
}

enum CheckInMode {
  ONLINE
  OFFLINE

  @@map("check_in_mode")
}

enum CheckInStatus {
  SUCCESS
  INVALID_QR
  ALREADY_USED
  WRONG_CONCERT
  CANCELLED_TICKET
  EXPIRED
  UNAUTHORIZED
  CONFLICT

  @@map("check_in_status")
}

enum CheckInSyncStatus {
  SYNCED
  PENDING
  FAILED

  @@map("check_in_sync_status")
}

enum NotificationType {
  ORDER_PAID
  TICKET_ISSUED
  CONCERT_REMINDER
  CONCERT_CANCELLED

  @@map("notification_type")
}

enum NotificationChannel {
  APP
  EMAIL

  @@map("notification_channel")
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED

  @@map("notification_status")
}

enum ArtistBioJobStatus {
  UPLOADED
  PROCESSING
  COMPLETED
  FAILED

  @@map("artist_bio_job_status")
}
enum ArtistDocumentStatus {
  UPLOADED   @map("uploaded")
  EXTRACTING @map("extracting")
  EXTRACTED  @map("extracted")
  GENERATING @map("generating")
  DONE       @map("done")
  FAILED     @map("failed")

  @@map("artist_document_status")
}

enum AiArtistBioStatus {
  GENERATING @map("generating")
  DONE       @map("done")
  FAILED     @map("failed")

  @@map("ai_artist_bio_status")
}

enum ImportStatus {
  DETECTED
  PENDING
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  FAILED_TO_ENQUEUE
  RETRYABLE_FAILED

  @@map("import_status")
}

enum ImportErrorType {
  FILE
  ROW
  DUPLICATE

  @@map("import_error_type")
}

enum VipGuestStatus {
  ACTIVE
  CHECKED_IN
  CANCELLED

  @@map("vip_guest_status")
}

// =====================
// AUTHORIZATION
// Giá»¯ nguyÃªn pháº§n Ä‘Ã£ cÃ³, chá»‰ bá»• sung relation field vÃ o User
// =====================

model User {
  id           String     @id @default(uuid()) @db.Uuid
  email        String     @unique
  passwordHash String     @map("password_hash")
  displayName  String?    @map("display_name")
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  userRoles     UserRole[]
  refreshTokens RefreshToken[]

  // Relations nghiá»‡p vá»¥ TicketBox
  concerts           Concert[]           @relation("ConcertOrganizer")
  checkInAssignments      CheckInAssignment[]      @relation("CheckInStaffAssignments")
  checkInStaffAssignments CheckInStaffAssignment[] @relation("CheckInStaffAssignmentUser")
  orders             Order[]
  tickets            Ticket[]
  checkIns           CheckIn[]           @relation("CheckInStaff")
  notifications      Notification[]
  artistBioJobs      ArtistBioJob[]      @relation("ArtistBioUploader")

  @@map("users")
}

model Role {
  id              String           @id @default(uuid()) @db.Uuid
  code            String           @unique
  name            String
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id              String           @id @default(uuid()) @db.Uuid
  code            String           @unique
  description     String?
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  rolePermissions RolePermission[]

  @@map("permissions")
}

model UserRole {
  userId    String   @map("user_id") @db.Uuid
  roleId    String   @map("role_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String   @map("role_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("refresh_tokens")
}
// =====================
// CONCERTS & TICKET TYPES
// =====================

model Concert {
  id          String @id @default(uuid()) @db.Uuid
  organizerId String @map("organizer_id") @db.Uuid

  title        String
  artistName   String? @map("artist_name")
  description  String? @db.Text
  venueName    String  @map("venue_name")
  venueAddress String? @map("venue_address") @db.Text
  bannerUrl    String? @map("banner_url")
  seatingSvg   String? @map("seating_svg") @db.Text

  status   ConcertStatus @default(DRAFT)
  startsAt DateTime      @map("starts_at")
  endsAt   DateTime?     @map("ends_at")
  performanceStartAt DateTime? @map("performance_start_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organizer          User                @relation("ConcertOrganizer", fields: [organizerId], references: [id])
  ticketTypes        TicketType[]
  orders             Order[]
  tickets            Ticket[]
  checkIns           CheckIn[]
  checkInAssignments      CheckInAssignment[]
  checkInStaffAssignments CheckInStaffAssignment[] @relation("CheckInStaffAssignmentConcert")
  notifications      Notification[]
  artistBioJobs      ArtistBioJob[]
  artistDocuments    ArtistDocument[]
  aiArtistBios       AiArtistBio[]
  vipGuestImports    VipGuestImport[]
  vipGuests          VipGuest[]

  @@index([status])
  @@index([startsAt])
  @@index([status, startsAt])
  @@map("concerts")
}

model TicketType {
  id        String @id @default(uuid()) @db.Uuid
  concertId String @map("concert_id") @db.Uuid

  code String
  name String

  priceVnd         Int @map("price_vnd")
  totalQuantity    Int @map("total_quantity")
  reservedQuantity Int @default(0) @map("reserved_quantity")
  soldQuantity     Int @default(0) @map("sold_quantity")
  perUserLimit     Int @map("per_user_limit")

  saleStartAt DateTime  @map("sale_start_at")
  saleEndAt   DateTime? @map("sale_end_at")

  status    TicketTypeStatus @default(ACTIVE)
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  concert    Concert     @relation(fields: [concertId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]
  tickets    Ticket[]

  @@unique([concertId, code])
  @@index([concertId])
  @@index([concertId, status])
  @@map("ticket_types")
}

// =====================
// ORDERS & PAYMENTS
// =====================

model Order {
  id        String @id @default(uuid()) @db.Uuid
  orderCode String @unique @map("order_code")

  userId    String @map("user_id") @db.Uuid
  concertId String @map("concert_id") @db.Uuid

  status         OrderStatus @default(PENDING)
  totalAmountVnd Int         @map("total_amount_vnd")

  expiresAt      DateTime  @map("expires_at")
  paidAt         DateTime? @map("paid_at")
  idempotencyKey String    @map("idempotency_key")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user     User                 @relation(fields: [userId], references: [id])
  concert  Concert              @relation(fields: [concertId], references: [id])
  items    OrderItem[]
  payments PaymentTransaction[]
  tickets  Ticket[]

  @@unique([userId, idempotencyKey])
  @@index([userId])
  @@index([concertId])
  @@index([status])
  @@index([expiresAt])
  @@map("orders")
}

model OrderItem {
  id           String @id @default(uuid()) @db.Uuid
  orderId      String @map("order_id") @db.Uuid
  ticketTypeId String @map("ticket_type_id") @db.Uuid

  quantity     Int
  unitPriceVnd Int @map("unit_price_vnd")
  subtotalVnd  Int @map("subtotal_vnd")

  order      Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  ticketType TicketType @relation(fields: [ticketTypeId], references: [id])
  tickets    Ticket[]

  @@index([orderId])
  @@index([ticketTypeId])
  @@map("order_items")
}

model PaymentTransaction {
  id      String @id @default(uuid()) @db.Uuid
  orderId String @map("order_id") @db.Uuid

  provider              PaymentProvider
  providerTransactionId String?         @map("provider_transaction_id")
  providerRequestId     String           @unique @default(uuid()) @map("provider_request_id")
  idempotencyKey        String          @unique @map("idempotency_key")
  requestFingerprint    String           @default("legacy") @map("request_fingerprint") @db.VarChar(64)

  status    PaymentStatus @default(INITIATED)
  amountVnd Int           @map("amount_vnd")
  paymentUrl String?       @map("payment_url") @db.Text
  failureCode String?      @map("failure_code") @db.VarChar(100)

  requestedAt DateTime  @default(now()) @map("requested_at")
  confirmedAt DateTime? @map("confirmed_at")
  initiationLeaseUntil DateTime? @map("initiation_lease_until")
  reconciliationLeaseUntil DateTime? @map("reconciliation_lease_until")
  lastReconciledAt DateTime? @map("last_reconciled_at")
  reconciliationAttempts Int @default(0) @map("reconciliation_attempts")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([provider, providerTransactionId])
  @@index([orderId])
  @@index([status])
  @@index([status, updatedAt])
  @@index([reconciliationLeaseUntil])
  @@map("payment_transactions")
}

// =====================
// TICKETS & CHECK-IN
// =====================

model Ticket {
  id         String @id @default(uuid()) @db.Uuid
  ticketCode String @unique @map("ticket_code")
  qrHash     String @unique @map("qr_hash")

  orderId      String @map("order_id") @db.Uuid
  orderItemId  String @map("order_item_id") @db.Uuid
  ownerUserId  String @map("owner_user_id") @db.Uuid
  concertId    String @map("concert_id") @db.Uuid
  ticketTypeId String @map("ticket_type_id") @db.Uuid

  status      TicketStatus @default(ACTIVE)
  issuedAt    DateTime     @default(now()) @map("issued_at")
  checkedInAt DateTime?    @map("checked_in_at")
  createdAt   DateTime     @default(now()) @map("created_at")

  order      Order      @relation(fields: [orderId], references: [id])
  orderItem  OrderItem  @relation(fields: [orderItemId], references: [id])
  owner      User       @relation(fields: [ownerUserId], references: [id])
  concert    Concert    @relation(fields: [concertId], references: [id])
  ticketType TicketType @relation(fields: [ticketTypeId], references: [id])
  checkIns   CheckIn[]

  @@index([ownerUserId])
  @@index([concertId])
  @@index([ticketTypeId])
  @@index([status])
  @@map("tickets")
}

model CheckIn {
  id String @id @default(uuid()) @db.Uuid

  ticketId   String? @map("ticket_id") @db.Uuid
  vipGuestId String? @map("vip_guest_id") @db.Uuid

  concertId   String @map("concert_id") @db.Uuid
  staffUserId String @map("staff_user_id") @db.Uuid

  localScanId    String? @map("local_scan_id")
  sourceDeviceId String? @map("source_device_id")

  mode       CheckInMode
  status     CheckInStatus
  syncStatus CheckInSyncStatus @default(SYNCED) @map("sync_status")

  scannedAt          DateTime  @map("scanned_at")
  clientScannedAt    DateTime? @map("client_scanned_at")
  serverReceivedAt   DateTime  @default(now()) @map("server_received_at")
  serverCheckedInAt  DateTime? @map("server_checked_in_at")
  syncedAt           DateTime? @map("synced_at")
  note               String?   @db.Text
  createdAt          DateTime  @default(now()) @map("created_at")

  ticket    Ticket?   @relation(fields: [ticketId], references: [id])
  vipGuest  VipGuest? @relation(fields: [vipGuestId], references: [id])
  concert   Concert   @relation(fields: [concertId], references: [id])
  staffUser User      @relation("CheckInStaff", fields: [staffUserId], references: [id])

  @@index([ticketId])
  @@index([vipGuestId])
  @@index([concertId])
  @@index([staffUserId])
  @@index([sourceDeviceId])
  @@index([sourceDeviceId, localScanId])
  @@index([scannedAt])
  @@index([serverReceivedAt])
  @@index([serverCheckedInAt])
  @@map("check_ins")
}

model CheckInAssignment {
  id          String @id @default(uuid()) @db.Uuid
  staffUserId String @map("staff_user_id") @db.Uuid
  concertId   String @map("concert_id") @db.Uuid

  gateName       String?  @map("gate_name")
  sourceDeviceId String?  @map("source_device_id")
  active         Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  staffUser User    @relation("CheckInStaffAssignments", fields: [staffUserId], references: [id], onDelete: Cascade)
  concert   Concert @relation(fields: [concertId], references: [id], onDelete: Cascade)

  @@unique([staffUserId, concertId, gateName])
  @@index([staffUserId])
  @@index([concertId])
  @@index([sourceDeviceId])
  @@index([active])
  @@map("check_in_assignments")
}

model CheckInStaffAssignment {
  id         String   @id @default(uuid()) @db.Uuid
  concertId  String   @map("concert_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  gateLabel  String   @map("gate_label")
  assignedAt DateTime @default(now()) @map("assigned_at")

  concert Concert @relation("CheckInStaffAssignmentConcert", fields: [concertId], references: [id], onDelete: Cascade)
  user    User    @relation("CheckInStaffAssignmentUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([concertId, userId])
  @@index([concertId])
  @@index([userId])
  @@map("check_in_staff_assignments")
}
// =====================
// NOTIFICATIONS
// =====================

model Notification {
  id        String  @id @default(uuid()) @db.Uuid
  userId    String  @map("user_id") @db.Uuid
  concertId String? @map("concert_id") @db.Uuid

  type    NotificationType
  channel NotificationChannel
  status  NotificationStatus  @default(PENDING)

  subject String?
  body    String  @db.Text

  scheduledAt DateTime? @map("scheduled_at")
  sentAt      DateTime? @map("sent_at")
  readAt      DateTime? @map("read_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  concert Concert? @relation(fields: [concertId], references: [id])

  @@index([userId])
  @@index([concertId])
  @@index([status])
  @@index([scheduledAt])
  @@map("notifications")
}

// =====================
// AI ARTIST BIO
// =====================

model ArtistBioJob {
  id         String @id @default(uuid()) @db.Uuid
  concertId  String @map("concert_id") @db.Uuid
  uploadedBy String @map("uploaded_by") @db.Uuid

  fileName      String  @map("file_name")
  storageKey    String  @map("storage_key")
  extractedText String? @map("extracted_text") @db.Text
  generatedBio  String? @map("generated_bio") @db.Text
  failureReason String? @map("failure_reason") @db.Text

  status    ArtistBioJobStatus @default(UPLOADED)
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")

  concert Concert @relation(fields: [concertId], references: [id], onDelete: Cascade)
  user    User    @relation("ArtistBioUploader", fields: [uploadedBy], references: [id])

  @@index([concertId])
  @@index([status])
  @@map("artist_bio_jobs")
}


model ArtistDocument {
  id            String               @id @default(uuid()) @db.Uuid
  concertId     String               @map("concert_id") @db.Uuid
  fileName      String               @map("file_name")
  storageKey    String               @map("storage_key")
  status        ArtistDocumentStatus @default(UPLOADED)
  extractedText String?              @map("extracted_text") @db.Text
  uploadedAt    DateTime             @default(now()) @map("uploaded_at")
  createdAt     DateTime             @default(now()) @map("created_at")

  concert Concert      @relation(fields: [concertId], references: [id], onDelete: Cascade)
  bio     AiArtistBio?

  @@index([concertId, createdAt])
  @@index([status, createdAt])
  @@map("artist_documents")
}

model AiArtistBio {
  id            String            @id @default(uuid()) @db.Uuid
  documentId    String            @unique @map("document_id") @db.Uuid
  concertId     String            @map("concert_id") @db.Uuid
  status        AiArtistBioStatus @default(GENERATING)
  generatedBio  String?           @map("generated_bio") @db.Text
  failureReason String?           @map("failure_reason") @db.VarChar(500)
  generatedAt   DateTime?         @map("generated_at")
  createdAt     DateTime          @default(now()) @map("created_at")

  document ArtistDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  concert  Concert        @relation(fields: [concertId], references: [id], onDelete: Cascade)

  @@index([concertId, status, createdAt])
  @@map("ai_artist_bios")
}

// =====================
// VIP GUEST LIST CSV
// =====================

model VipGuestImport {
  id        String @id @default(uuid()) @db.Uuid
  concertId String @map("concert_id") @db.Uuid

  sourceName        String       @default("SPONSOR_CSV") @map("source_name")
  fileName          String       @map("file_name")
  sourcePath        String?      @map("source_path")
  sourceFingerprint String       @map("source_fingerprint")
  status            ImportStatus @default(PENDING)
  totalRows         Int          @default(0) @map("total_rows")
  acceptedRows      Int          @default(0) @map("accepted_rows")
  rejectedRows      Int          @default(0) @map("rejected_rows")
  duplicateRows     Int          @default(0) @map("duplicate_rows")
  failureCode       String?      @map("failure_code")
  failureMessage    String?      @map("failure_message") @db.Text

  queuedAt   DateTime? @map("queued_at")
  startedAt  DateTime? @map("started_at")
  importedAt DateTime? @map("imported_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  concert   Concert               @relation(fields: [concertId], references: [id], onDelete: Cascade)
  guests    VipGuest[]
  errors    VipGuestImportError[]
  auditLogs AuditLog[]

  @@unique([concertId, sourceName, sourceFingerprint])
  @@index([concertId])
  @@index([concertId, status])
  @@index([status, createdAt])
  @@index([sourceFingerprint])
  @@map("vip_guest_imports")
}

model VipGuest {
  id        String @id @default(uuid()) @db.Uuid
  importId  String @map("import_id") @db.Uuid
  concertId String @map("concert_id") @db.Uuid

  sponsorSource    String  @default("SPONSOR_CSV") @map("sponsor_source")
  externalGuestKey String? @map("external_guest_key")
  qrHash           String? @unique @map("qr_hash")

  fullName              String  @map("full_name")
  email                 String?
  phone                 String?
  sponsorCompany        String? @map("sponsor_company")
  invitedBy             String? @map("invited_by")
  guestType             String? @map("guest_type")
  allowedGate           String? @map("allowed_gate")
  notes                 String?
  normalizedFullName    String  @default("") @map("normalized_full_name")
  normalizedEmail       String? @map("normalized_email")
  normalizedPhone       String? @map("normalized_phone")
  normalizedIdentityKey String? @map("normalized_identity_key")
  sourceRowNumber       Int?    @map("source_row_number")

  status      VipGuestStatus @default(ACTIVE)
  checkedInAt DateTime?      @map("checked_in_at")
  importedAt  DateTime       @default(now()) @map("imported_at")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  import   VipGuestImport @relation(fields: [importId], references: [id], onDelete: Cascade)
  concert  Concert        @relation(fields: [concertId], references: [id], onDelete: Cascade)
  checkIns CheckIn[]

  @@unique([concertId, sponsorSource, externalGuestKey])
  @@index([concertId])
  @@index([concertId, status])
  @@index([concertId, sponsorSource])
  @@index([email])
  @@index([phone])
  @@index([normalizedEmail])
  @@index([normalizedPhone])
  @@index([normalizedIdentityKey])
  @@index([status])
  @@map("vip_guests")
}

model VipGuestImportError {
  id       String @id @default(uuid()) @db.Uuid
  importId String @map("import_id") @db.Uuid

  type      ImportErrorType
  rowNumber Int?            @map("row_number")
  field     String?
  code      String
  message   String          @db.Text
  rawRow    Json?           @map("raw_row")
  metadata  Json?
  createdAt DateTime        @default(now()) @map("created_at")

  import VipGuestImport @relation(fields: [importId], references: [id], onDelete: Cascade)

  @@index([importId])
  @@index([importId, type])
  @@index([importId, rowNumber])
  @@map("vip_guest_import_errors")
}

model AuditLog {
  id          String  @id @default(uuid()) @db.Uuid
  actorUserId String? @map("actor_user_id") @db.Uuid
  importId    String? @map("import_id") @db.Uuid

  entityType String  @map("entity_type")
  entityId   String  @map("entity_id")
  action     String
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  import VipGuestImport? @relation(fields: [importId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([entityType, entityId])
  @@index([importId])
  @@index([createdAt])
  @@map("audit_logs")
}
